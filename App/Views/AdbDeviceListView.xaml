<UserControl
    x:Class="App.Views.AdbDeviceListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="8">
            <Button x:Name="RefreshButton" Content="刷新设备" Click="RefreshButton_Click"/>
            <Button x:Name="ConnectButton" Content="连接设备" Click="ConnectButton_Click"/>
        </StackPanel>

        <!-- 设备列表 -->
        <ListView
            x:Name="DeviceListView"
            Grid.Row="1"
            SelectionMode="Single"
            SelectionChanged="DeviceListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Serial}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Model}" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding State}" FontSize="12"/>
                            <TextBlock Text="{Binding ConnectionType}" FontSize="10" Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- TCP/IP 连接 -->
        <StackPanel Grid.Row="2" Padding="8" Spacing="8">
            <TextBlock Text="TCP/IP 连接" FontWeight="SemiBold"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TcpIpTextBox" PlaceholderText="192.168.1.100:5555"/>
                <Button Grid.Column="1" Content="连接" Click="TcpIpConnectButton_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
