<UserControl
    x:Class="App.Views.AdbDeviceListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="12">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="RefreshButton"
                        Grid.Column="0"
                        Content="刷新"
                        Click="RefreshButton_Click"
                        Style="{StaticResource WorkbenchSecondaryButtonStyle}" />

                <Button x:Name="DiscoverButton"
                        Grid.Column="1"
                        Content="扫描"
                        Click="DiscoverButton_Click"
                        Style="{StaticResource WorkbenchSecondaryButtonStyle}" />

                <Button x:Name="WirelessButton"
                        Grid.Column="2"
                        Content="无线连接"
                        HorizontalAlignment="Right"
                        Click="WirelessButton_Click"
                        Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="12,12,12,8" Spacing="2">
                    <TextBlock Text="设备列表" Style="{StaticResource WorkbenchSectionTitleTextStyle}" />
                    <TextBlock x:Name="DeviceCountText"
                               Text="选择设备后即可截图、拉取 UI 树和执行测试。"
                               Style="{StaticResource WorkbenchCaptionTextStyle}" />
                </StackPanel>

                <ListView x:Name="DeviceListView"
                          Grid.Row="1"
                          Padding="6,0,6,6"
                          SelectionMode="Single"
                          SelectionChanged="DeviceListView_SelectionChanged"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="MinHeight" Value="76" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding Serial}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Model}" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding State}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding ConnectionType}"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <ContentDialog x:Name="WirelessConnectionDialog"
                       Title="无线调试连接"
                       CloseButtonText="关闭"
                       DefaultButton="Close">
            <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <Border Style="{StaticResource WorkbenchCardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="首次配对（只需一次）" FontWeight="SemiBold" />
                            <TextBlock Text="手机操作：设置 → 无线调试 → 使用配对码配对设备。"
                                       Style="{StaticResource WorkbenchCaptionTextStyle}" />
                            <Grid ColumnSpacing="8" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP" VerticalAlignment="Center" />
                                <TextBox x:Name="PairIpTextBox" Grid.Row="0" Grid.Column="1" PlaceholderText="192.168.3.4" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="端口" VerticalAlignment="Center" />
                                <TextBox x:Name="PairPortTextBox" Grid.Row="1" Grid.Column="1" PlaceholderText="39063" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="配对码" VerticalAlignment="Center" />
                                <TextBox x:Name="PairingCodeTextBox" Grid.Row="2" Grid.Column="1" PlaceholderText="123456" />

                                <Button Grid.Row="3"
                                        Grid.Column="1"
                                        Content="执行配对"
                                        Click="PairButton_Click"
                                        Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="直接连接" FontWeight="SemiBold" />
                            <TextBlock Text="手机操作：返回无线调试主界面，查看顶部显示的 IP 和端口。"
                                       Style="{StaticResource WorkbenchCaptionTextStyle}" />
                            <Grid ColumnSpacing="8" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP" VerticalAlignment="Center" />
                                <TextBox x:Name="ConnectIpTextBox" Grid.Row="0" Grid.Column="1" PlaceholderText="192.168.3.4" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="端口" VerticalAlignment="Center" />
                                <TextBox x:Name="ConnectPortTextBox" Grid.Row="1" Grid.Column="1" PlaceholderText="41581" />

                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        Content="连接到设备"
                                        Click="ConnectButton_Click"
                                        Style="{StaticResource WorkbenchPrimaryButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</UserControl>
