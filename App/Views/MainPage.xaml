<Page
    x:Class="App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Name="CaptureButton" Label="截图" Click="CaptureButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Camera"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="DumpUiButton" Label="拉取 UI 树" Click="DumpUiButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="ViewAll"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="GenerateCodeButton" Label="生成代码" Click="GenerateCodeButton_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE943;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="MatchTestButton" Label="匹配测试" Click="MatchTestButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Find"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="FitToWindowButton" Label="适应窗口" Click="FitToWindowButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="FullScreen"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ResetViewButton" Label="原图 (1:1)" Click="ResetViewButton_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7C4;"/>
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：设备列表 -->
            <local:AdbDeviceListView x:Name="DeviceList" Grid.Column="0"/>

            <!-- 中央：画布 -->
            <local:CanvasView x:Name="Canvas" Grid.Column="1"/>

            <!-- 右侧：属性面板 + 代码预览 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:PropertyPanelView x:Name="PropertyPanel" Grid.Row="0"/>
                <local:CodePreviewView x:Name="CodePreview" Grid.Row="1"/>
            </Grid>
        </Grid>

        <!-- 底部状态栏 + 调试日志 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 状态栏 -->
            <Grid Grid.Row="0" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Grid.Column="0" Text="就绪" Margin="0,0,16,0"/>
                <TextBlock x:Name="ScaleText" Grid.Column="1" Text="缩放: 100%" Margin="0,0,16,0"/>
                <TextBlock x:Name="ResolutionText" Grid.Column="2" Text="分辨率: -" Margin="0,0,16,0"/>
                <Button x:Name="ToggleDebugButton" Grid.Column="4" Content="调试日志" Click="ToggleDebugButton_Click"
                        Background="Transparent" BorderThickness="0" Padding="8,4"/>
            </Grid>

            <!-- 调试日志面板（默认折叠）-->
            <Border Grid.Row="1" x:Name="DebugPanel" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0"
                    MaxHeight="200" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="DebugLogText" Padding="8" FontFamily="Consolas" FontSize="11"
                             TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
